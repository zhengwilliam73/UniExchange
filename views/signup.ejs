<body>
   


        <div class = "form-container">
        <form action = "/" method= "login" enctype="multipart/form-data">
                <div>
                        <label for = "username" >Create Username Here:</label>
                        <textarea id = "username" name = "username" style = "width: 100px; height: 30px;" rows = "5" cols = "50"required></textarea>
