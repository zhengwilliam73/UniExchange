<!DOCTYPE html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login and Sign Up!</title>
    <link rel="stylesheet" href="style.css">
  </head>

<body id="top" style="margin: 24px; line-height: 1.6; font-family: Arial, sans-serif;">
    <!-- Header -->
    <header>
      <h1 style="text-align: center; font-weight: bold;">Sign Up</h1>
    </header>
     <!-- Navigation menu: links to other pages -->
    <%- include('./partials/nav.ejs') %>

    <!-- Header: links to other pages -->
     <%- include('./partials/head.ejs') %>
   

<!-- Updated by Jacky Jiang 2/27/2026-->
<div class="form-container">
  <form action="/signup" method="POST">
    
    <div>
      <label for="username">Create Username Here:</label><br>
      <input type="text" id="username" name="username" required style="width: 250px; height: 30px;">
    </div>
    <br>

    <div>
      <label for="password">Create Password:</label><br>
      <input type="password" id="password" name="password" required style="width: 250px; height: 30px;">
    </div>
    <br>

    <ul id="passwordCriteria" style="font-size:14px; list-style:none; padding-left:0;">
      <li id="length" style="color:red;"><span class="icon">✖</span> At least 8 characters</li>
      <li id="upper" style="color:red;"><span class="icon">✖</span> At least one uppercase letter</li>
      <li id="lower" style="color:red;"><span class="icon">✖</span> At least one lowercase letter</li>
      <li id="number" style="color:red;"><span class="icon">✖</span> At least one number</li>
      <li id="special" style="color:red;"><span class="icon">✖</span> At least one special character (!@#$%^&*)</li>
    </ul>

    <!-- Submit Button -->
    <button type="submit">Sign Up</button>
  </form>
</div>

<!-- Written by Jacky Jiang 2/26/2026-->
<script>
  const passwordInput = document.getElementById("password");

  passwordInput.addEventListener("input", function () {
    const password = passwordInput.value;

    // Check each individual rule
    const hasMinLength = password.length >= 8;
    const hasUpper = /[A-Z]/.test(password);
    const hasLower = /[a-z]/.test(password);
    const hasNumber = /[0-9]/.test(password);
    const hasSpecial = /[!@#$%^&*]/.test(password);

    // Update the <li> for each rule
    updateRule("length", hasMinLength);
    updateRule("upper", hasUpper);
    updateRule("lower", hasLower);
    updateRule("number", hasNumber);
    updateRule("special", hasSpecial);

    // Disables submit if weak (common password or missing rules)
    const submitButton = document.querySelector("button[type='submit']");
    if (isCommon || !hasMinLength || !hasUpper || !hasLower || !hasNumber || !hasSpecial) {
      submitButton.disabled = true;
    } else {
      submitButton.disabled = false;
    }
  });

  // Function to update each <li> visually
  function updateRule(id, condition) {
    const element = document.getElementById(id);
    const icon = element.querySelector(".icon");
    if (condition) {
      element.style.color = "green";
      icon.textContent = "✔";
    } else {
      element.style.color = "red";
      icon.textContent = "✖";
    }
  }
</script>

</body>
</html>

