<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>UniExchange - Drexel Marketplace</title>
    <link rel = "stylesheet" href = "/style.css">
</head>
	
<body>
    <!-- Header section: UniExchange title and image side by side -->
    <div style="display: flex; align-items: center;">
        <!-- Site name with some space to the right -->
        <h3 style="margin-right: 20px;">UniExchange</h3>

        <!-- Image of drexel logo -->
        <img src="drexel2.png" alt="Drexel students exchanging items" width="100">
    </div>

	<!-- Navigation menu: links to other pages -->
    <%- include('./partials/nav.ejs') %>

    <!-- Header: links to other pages -->
     <%- include('./partials/head.ejs') %>
    
     <!-- Footer: links to other pages-->
    <%- include('./partials/head.ejs') %>

    <!-- Main title of the homepage -->
    <h1>Marketplace for Drexel</h1>

    <!-- Brief description of the site's purpose -->
    <p>Check out Drexel's marketplace hub, helping students buy and sell securely.</p>

    <div class = "posts content">
        <h2>Posts:</h2>
        <% if (posts.length > 0) { %>
            <% posts.forEach(post => { %>
                <div class ="card">
                    <a class="single" href=/<%= post._id %>>
                    <h3 class="title"><%= post.title %></h3>
                    </a>
                    <p class="description"><%= post.body %></p>
                    <p class="condition">Condition: <%= post.condition %></p>
                    <p class="price">Price: $<%= post.price %></p>
                    <p class="location">Location: <%= post.location %></p>
                </div>

             <% }) %>
         <% } else { %>
             <p>There are no posts to display...</p>
         <% } %>
    </div>
</body>
</html>

