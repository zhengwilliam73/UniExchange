<!-- File made by Frank.
    - Displays an edit form for an existing 
    post and pre-fills the form with data
    from MongoDB
    - Submits updated data to Express
    and updates the post     
-->
<!DOCTYPE html>
<html>

<head>
    <%- include('./partials/head.ejs') %>
</head>

<body>
    <%- include('./partials/nav.ejs') %>

    <div class="form-container">
        <form action="/posts/<%= post._id %>" method="POST">
            
            <div>
                <label for="title">Title:</label>
                <textarea
                    id="title"
                    name="title"
                    style="width: 500px; height: 60px;"
                    required
                ><%= post.title %></textarea>
            </div>
            <br>

            <div>
                <label for="description">Description:</label>
                <textarea
                    id="description"
                    name="description"
                    style="width: 500px; height: 60px;"
                    required
                ><%= post.description %></textarea>
            </div>
            <br>

            <div>
                <label for="condition">Condition:</label>
                <select id="condition" name="condition">
                    <option value="New" <%= post.condition === 'New' ? 'selected' : '' %>>New</option>
                    <option value="Fairly New" <%= post.condition === 'Fairly New' ? 'selected' : '' %>>Fairly New</option>
                    <option value="Acceptable" <%= post.condition === 'Acceptable' ? 'selected' : '' %>>Acceptable</option>
                    <option value="Used" <%= post.condition === 'Used' ? 'selected' : '' %>>Used</option>
                    <option value="Poor" <%= post.condition === 'Poor' ? 'selected' : '' %>>Poor</option>
                </select>
            </div>
            <br>

            <div>
                <label for="price">Price:</label>
                <input
                    type="number"
                    id="price"
                    name="price"
                    value="<%= post.price %>"
                    required
                >
            </div>
            <br>

            <div>
                <label for="location">Location:</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    value="<%= post.location %>"
                    style="width: 300px;"
                    required
                >
            </div>
            
            <div>
                <input type="reset">
            </div>
            
            <br>

    

            <div>
                <br>
                <button type="submit">Update post</button>
            </div>

        </form>
    </div>

    <div class="card">
        <img id="theImage" src="" />
        <h2 id="theTitle"></h2>
        <p id="theDescription"></p>
        <p id="theCondition"></p>
        <p id="thePrice"></p>
        <p id="theLocation"></p>
    </div>

    <script src="script.js"></script>
    <%- include('./partials/footer.ejs') %>
</body>
</html>
