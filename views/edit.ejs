<!-- File made by Frank. Copy and pasted the code from post with a few changes to include hardcoded data 
  when the user clicks on the edit button--->
<!DOCTYPE html>
<html>

<head>
    <%- include('./partials/head.ejs') %>
</head>

<body>
    <%- include('./partials/nav.ejs') %>


        <div class = "form-container">
        <form action = "/" method= "POST">
                <div>
                        <label for = "title" >Title:</label>
                        <textarea id="title" name="title" required>Hard coded title</textarea>
                </div>
                <br>

                <div>
                        <label for = "description" >Description:</label>
                        <textarea id="description" name="description" required>
                        Hard coded description
                        </textarea>

                </div>
                <br>

                <div>
                        <label for = "condition" >Condition:</label>
                        <select id = "condition" name = "condition">
                                <option value = "New">New</option>
                                <option value = "Fairly New">Fairly New</option>
                                <option value = "Acceptable">Acceptable</option>
                                <option value = "Used">Used</option>
                                <option value = "Poor">Poor</option>
                        </select>
                </div>
                <br>

                <div>
                        <label for = "Price" >Price:</label>
                        <input type="number" id="price" name="price" value="25" required>
                </div>
                <br>

                <div>
                        <label for = "Location" >Location:</label>
                     <input type="text" id="location" name="location" value="Drexel" required>
                </div>
                <br>

		  <!-- <label for ="item">Upload an image of your item:

                </label>
		 <br>
                <input type ="file" id = "item" name="item"
                accept="image/png, image/jpeg" />
		 <br>
                <br> -->

	
                <div>
                        <input type = "reset">
                </div>
                <br>

                <div>
                        <button type="button" onclick="setValues()">Submit to this page</button>

                        <br>
                        <br>

                        <button type="submit">Submit as a post</button>
                </div>

        </form>
        </div>

	<div class="card">
		<img id = "theImage" src="" />
		<h2 id ="theTitle"></h2>
		<p id ="theDescription"></p>
		<p id ="theCondition"></p>
		<p id ="thePrice"></p>
		<p id ="theLocation"></p>
	</div>

	<script src="script.js"></script>

    <%- include('./partials/footer.ejs') %>
</body>



</html>
